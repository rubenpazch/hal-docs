# ─────────────────────────────────────────────────────────────────────────────
# hal-docs environment variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Rails ─────────────────────────────────────────────────────────────────────

# Required: contents of config/master.key (or RAILS_MASTER_KEY secret on AWS)
RAILS_MASTER_KEY=

# Required: at least 64 random hex characters — generate with: openssl rand -hex 64
SECRET_KEY_BASE=

# ── Database ──────────────────────────────────────────────────────────────────

# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://hal_docs:password@db/hal_docs_production

# Password for the local Compose postgres service
DB_PASSWORD=password

# ── Frontend ──────────────────────────────────────────────────────────────────

# The public URL of the frontend — Rails uses this for CORS
FRONTEND_URL=http://localhost

# Host port for the frontend Nginx container (default: 80)
APP_PORT=80

# ── AWS — Active Storage (S3) ─────────────────────────────────────────────────
# On ECS, attach an IAM task role with s3:GetObject / s3:PutObject permissions
# and set only AWS_REGION + AWS_BUCKET — no long-lived credentials needed.

AWS_REGION=us-east-1
AWS_BUCKET=hal-docs-storage-production

# ── Logging ───────────────────────────────────────────────────────────────────
RAILS_LOG_LEVEL=info
